<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="icon" href="/imagens/favicon.png" type="image/x-icon">
    <link rel="stylesheet" href="/css/tela_imoveis.css">
    <title>Imóveis</title>
</head>

<body>
    <div class="nav-imoveis">
        <a href="/" class="home"><i class="bi bi-house-door-fill"></i></a>
        <form action="/imoveis" method="GET">
            <select name="banheiros" id="banheiros">
                <option value="">Banheiros</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3 ou mais</option>
            </select>
            <select name="quartos" id="quartos">
                <option value="">Quartos</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4 ou mais</option>
            </select>
            <select name="tipo" id="tipo">
                <option value="">Tipo</option>
                <option value="Casa">Casa</option>
                <option value="Apartamento">Apartamento</option>
            </select>
            <select name="transacao" id="transacao">
                <option value="">Venda/Aluguel</option>
                <option value="Venda">Venda</option>
                <option value="Aluguel">Aluguel</option>
            </select>
            <button type="submit">Filtrar</button>
        </form>
    </div>
    <% if (imoveis.length> 0) {imoveis.forEach(imovel => { %>
        <div class="imovel-item" onclick="window.location.href='/imovel/<%= imovel.public_id %>'">
            <div id="left">
                <img src="<%= imovel.imagem_principal %>" alt="Imagem do imóvel">
                <div>
                    <h2>
                        <%= imovel.titulo %>
                    </h2>
                    <p><strong>Preço:</strong>
                        <%= imovel.valor %>
                    </p>
                </div>
            </div>
            <p id="descricao"><strong>Descrição:</strong>
                <%= imovel.descricao %>
            </p>

            <div id="right" class="spec-imovel-item">
                <p><strong><i class="bi bi-house"></i> Tipo:</strong>
                    <%= imovel.tipo %>
                </p>
                <p class="loc" title="<%= imovel.localizacao %>"><strong><i class="bi bi-geo-alt"></i>
                        Local:</strong>
                    <%= imovel.localizacao.length> 18 ? imovel.localizacao.slice(0, 18) + "...":
                        imovel.localizacao %>
                </p>
                <p><strong><i class="bi bi-door-closed"></i> Quartos:</strong>
                    <%= imovel.quarto %>
                </p>
                <p><strong><i class="bi bi-currency-dollar"></i> Disponível para:</strong>
                    <%= imovel.transacao %>
                </p>
                <p><strong><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true"
                            role="presentation" focusable="false"
                            style="height: 24px; width: 16px; fill: currentcolor;">
                            <path
                                d="M7.5 2a4.5 4.5 0 0 1 4.47 4H14v2H8V6h1.95A2.5 2.5 0 0 0 5 6.34V16h26v2h-2v5a5 5 0 0 1-3 4.58V30h-2v-2H8v2H6v-2.42a5 5 0 0 1-3-4.34V18H1v-2h2V6.5A4.5 4.5 0 0 1 7.5 2zM27 18H5v5a3 3 0 0 0 2.65 2.98l.17.01L8 26h16a3 3 0 0 0 3-2.82V23z">
                            </path>
                        </svg> Banheiros:</strong>
                    <%= imovel.banheiro %>
                </p>
                <p><strong><i class="bi bi-house-gear"></i> Metragem:</strong>
                    <%= imovel.metragem %> m²
                </p>
            </div>
        </div>
        <% });%>
            <%} else {%>
                Nenhum imóvel encontrado com os critérios selecionados.
                <%}%>

                    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
                        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
                        crossorigin="anonymous"></script>
</body>

</html>